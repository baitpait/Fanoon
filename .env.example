# =============================================================================
# Anagheem Home — Backend (لوحة + API) | نسخة مثال للبيئة
# النشر: Document root على السيرفر = مجلد public داخل المشروع
# مثال cPanel: /home/baitpait/public_html/admin  ← جذر Laravel
#              /home/baitpait/public_html/admin/public ← جذر الويب (الدومين)
# الدومين: https://admin.anagheemhome.com
# =============================================================================

APP_NAME="Anagheem"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_MODE=live
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# الإنتاج: ضع الدومين الفعلي للوحة والـ API
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://admin.anagheemhome.com
# FORCE_HTTPS=true

# بريد تلقائي للعملاء بدون إيميل (u{phone}@domain)
AUTO_EMAIL_DOMAIN=anagheemhome.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=anagheem
DB_USERNAME=root
DB_PASSWORD=

# استيراد ووردبريس (أمر import:wordpress-woocommerce) — قاعدة مؤقتة فقط
# WP_IMPORT_DATABASE=wp_anagheem_import
# WP_IMPORT_DB_HOST=127.0.0.1
# WP_IMPORT_DB_PORT=3306
# WP_IMPORT_DB_USERNAME=root
# WP_IMPORT_DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# الإنتاج على HTTPS:
# SESSION_SECURE_COOKIE=true
# SESSION_DOMAIN=.anagheemhome.com
# SESSION_SAME_SITE=lax

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

NGINX_PORT=8400
FORCE_HTTPS=false

# CORS — واجهات أخرى (موقع، Flutter Web، نطاقات فرعية)
# اتركها فارغة في local: يُسمح بـ * أو الأنماط في config/cors.php
# الإنتاج: اذكر كل الأصول صراحة (مفصولة بفاصلة، بدون مسافات بعد الفاصلة)
# CORS_ALLOWED_ORIGINS=https://anagheemhome.com,https://www.anagheemhome.com,https://admin.anagheemhome.com

GUEST_VALIDATE_IP=true

GOOGLE_TRANSLATE_API_KEY=
