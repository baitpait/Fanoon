# =============================================================================
# Fanoon — Backend (لوحة + API) | نسخة مثال للبيئة
# النشر: Document root على السيرفر = مجلد public داخل المشروع
# =============================================================================

APP_NAME="Fanoon"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_MODE=live
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# الإنتاج: ضع الدومين الفعلي للوحة والـ API
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://admin.anagheemhome.com
# FORCE_HTTPS=true

# بريد تلقائي للعملاء بدون إيميل (u{phone}@domain)
AUTO_EMAIL_DOMAIN=anagheemhome.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fanoon
DB_USERNAME=root
DB_PASSWORD=

# استيراد ووردبريس (أمر import:wordpress-woocommerce) — قاعدة مؤقتة فقط
# WP_IMPORT_DATABASE=wp_anagheem_import
# WP_IMPORT_DB_HOST=127.0.0.1
# WP_IMPORT_DB_PORT=3306
# WP_IMPORT_DB_USERNAME=root
# WP_IMPORT_DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# الإنتاج على HTTPS:
# SESSION_SECURE_COOKIE=true
# SESSION_DOMAIN=.anagheemhome.com
# SESSION_SAME_SITE=lax

