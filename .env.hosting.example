# ============================================
# إعدادات الاستضافة - elitepal.net
# انسخ هذا الملف إلى .env على السيرفر
# المسار: /home/baitpait/public_html/elitepalnet
# Document Root: .../elitepalnet/public
# ============================================

APP_NAME="Fanoon"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://elitepal.net
APP_MODE=live

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=baitpait_elitepal
DB_USERNAME=baitpait_elitepal
# كلمة المرور — استخدم علامات تنصيص لاحتواء رموز خاصة مثل <
DB_PASSWORD="YOUR_DB_PASSWORD"

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

FORCE_HTTPS=true
AUTO_EMAIL_DOMAIN=elitepal.net

# CORS — نطاقات التطبيق مفصولة بفاصلة (بدون مسافات بعد الفاصلة)
CORS_ALLOWED_ORIGINS=https://elitepal.net,https://www.elitepal.net

GUEST_VALIDATE_IP=true

GOOGLE_TRANSLATE_API_KEY=
